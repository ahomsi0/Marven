{
  "name": "marven",
  "version": "1.0.5",
  "description": "Marven - Local AI Desktop Assistant",
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "electron:dev": "node electron/create-icon.js && concurrently --kill-others-on-fail \"next dev -p 3000\" \"./node_modules/.bin/wait-on tcp:3000 && cross-env NODE_ENV=development ./node_modules/.bin/electron .\"",
    "electron:start": "cross-env NODE_ENV=development ./node_modules/.bin/electron .",
    "helper": "menubar-helper/MarvenHelper",
    "launch": "concurrently \"npm run dev\" \"sleep 3 && menubar-helper/MarvenHelper\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "electron:build": "next build && node scripts/prepare-standalone.js && electron-builder"
  },
  "build": {
    "appId": "com.marven.app",
    "productName": "Marven",
    "asar": false,
    "afterPack": "scripts/after-pack.js",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "!electron/assets/icon.svg"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "nextjs-server",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": ".next/static",
        "to": "nextjs-server/.next/static"
      },
      {
        "from": "public",
        "to": "nextjs-server/public"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "electron/assets/icon.png",
      "identity": null
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/assets/icon.png"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/assets/icon.png",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "ahomsi0",
      "repo": "Marven"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "next": "^15.5.15",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.6",
    "wait-on": "^9.0.10"
  }
}
