{
  "name": "marven",
  "version": "2.6.1",
  "description": "Marven - Local AI Desktop Assistant",
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "electron:dev": "node electron/create-icon.js && concurrently --kill-others-on-fail \"next dev -p 3000\" \"./node_modules/.bin/wait-on tcp:3000 && cross-env NODE_ENV=development ./node_modules/.bin/electron .\"",
    "electron:start": "cross-env NODE_ENV=development ./node_modules/.bin/electron .",
    "helper": "menubar-helper/MarvenHelper",
    "launch": "concurrently \"npm run dev\" \"sleep 3 && menubar-helper/MarvenHelper\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "node scripts/fix-node-pty-perms.js",
    "electron:build": "next build && node scripts/prepare-standalone.js && node scripts/fix-node-pty-perms.js && electron-builder"
  },
  "build": {
    "appId": "com.marven.app",
    "productName": "Marven",
    "asar": false,
    "afterPack": "scripts/after-pack.js",
    "afterSign": "scripts/after-sign.js",
    "asarUnpack": [
      "node_modules/node-pty/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "!electron/assets/icon.svg"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "nextjs-server",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "electron/assets/icon.png",
      "identity": null
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/assets/icon.png"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/assets/icon.png",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "Marven-Setup-${version}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "ahomsi0",
      "repo": "Marven",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@codemirror/autocomplete": "^6.20.2",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-php": "^6.0.2",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/lint": "^6.9.6",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.0",
    "@huggingface/transformers": "^4.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "codemirror": "^6.0.2",
    "diff": "^9.0.0",
    "electron-updater": "^6.8.3",
    "fix-path": "^5.0.0",
    "mammoth": "^1.12.0",
    "next": "^15.5.15",
    "node-pty": "^1.1.0",
    "openai": "^6.38.0",
    "pdf-parse": "^2.4.5",
    "prettier": "^3.8.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/diff": "^7.0.2",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.6",
    "wait-on": "^9.0.10"
  }
}
